{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[quarto]": {
        "editor.defaultFormatter": "quarto.quarto",
        "editor.indentSize": "tabSize",
        "editor.tabSize": 2
    },
    "[r]": {
        "editor.defaultFormatter": "Posit.air-vscode",
        "editor.indentSize": "tabSize",
        "editor.tabSize": 2
    },
    "chat.disableAIFeatures": true,
    "dataExplorer.summaryCollapsed": true,
    "editor.autoIndentOnPaste": true,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.cursorBlinking": "expand",
    "editor.cursorStyle": "block",
    "editor.detectIndentation": false,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.guides.bracketPairs": "active",
    "editor.inlineSuggest.syntaxHighlightingEnabled": true,
    "editor.minimap.enabled": true,
    "editor.renderFinalNewline": "dimmed",
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        80
    ],
    "editor.scrollBeyondLastLine": false,
    "editor.smoothScrolling": true,
    "editor.tabCompletion": "on",
    "editor.unicodeHighlight.invisibleCharacters": true,
    "editor.wordWrap": "on",
    "editor.wrapOnEscapedLineFeeds": true,
    "editor.wrappingStrategy": "advanced",
    "extensions.allowed": {
        "*": true,
        "meta.pyrefly": false,
        "posit.publisher": false
    },
    "files.associations": {
        "renv.lock": "json"
    },
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "git.autofetch": true,
    "git.blame.editorDecoration.enabled": true,
    "git.confirmSync": false,
    "git.defaultCloneDirectory": "~/repos",
    "git.enableCommitSigning": true,
    "git.suggestSmartCommit": false,
    "notebook.lineNumbers": "on",
    "notebook.showFoldingControls": "always",
    "notebook.workingDirectory": "${workspaceFolder}",
    "pastum.airFormat": false,
    "pastum.defaultConvention": "snake_case",
    "plots.darkFilter": "off",
    "positron.r.quietMode": true,
    "positron.r.workspaceSymbols.includeCommentSections": true,
    "projectManager.git.baseFolders": [
        "~/repos"
    ],
    "projectManager.showParentFolderInfoOnDuplicates": true,
    "projectManager.tags": [
        "R",
        "Python",
        "Website",
        "Other"
    ],
    "python.interpreters.exclude": [
        "/usr/bin/python3"
    ],
    "python.quietMode": true,
    "python.terminal.shellIntegration.enabled": true,
    "redhat.telemetry.enabled": false,
    "rewrap.autoWrap.enabled": true,
    "rewrap.reformat": true,
    "rewrap.wrappingColumn": 80,
    "terminal.external.osxExec": "/Applications/Ghostty.app",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.suggest.enabled": true,
    "window.autoDetectColorScheme": true,
    "workbench.activityBar.location": "top",
    "workbench.editor.empty.hint": "hidden",
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.keybindings.rstudioKeybindings": true,
    "jupyter.interactiveWindow.notebookRepl": true,
    "better-comments.highlightPlainText": true,
    "better-comments.tags": [
        {
            "tag": "!",
            "color": "#FF2D00",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "?",
            "color": "#3498DB",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "//",
            "color": "#474747",
            "strikethrough": true,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "todo",
            "color": "#FF8C00",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "*",
            "color": "#98C379",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        }
    ],
    "peacock.affectTitleBar": false
}
