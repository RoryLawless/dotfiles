{
	"[quarto]": {
		"editor.defaultFormatter": "quarto.quarto",
		"editor.formatOnPaste": true,
		"editor.formatOnSave": true,
		"editor.formatOnType": true
	},
	"[r]": {
		"editor.defaultFormatter": "Posit.air-vscode",
		"editor.formatOnPaste": true,
		"editor.formatOnSave": true,
		"editor.formatOnType": true
	},
	"chat.checkpoints.showFileChanges": true,
	"chat.edits2.enabled": true,
	"chat.useCopilotParticipantsWithOtherProviders": true,
	"dataExplorer.summaryCollapsed": true,
	"diffEditor.codeLens": true,
	"editor.autoIndentOnPaste": true,
	"editor.bracketPairColorization.independentColorPoolPerBracketType": true,
	"editor.cursorBlinking": "expand",
	"editor.cursorStyle": "block",
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.formatOnType": true,
	"editor.guides.bracketPairs": "active",
	"editor.inlineSuggest.syntaxHighlightingEnabled": true,
	"editor.minimap.enabled": true,
	"editor.renderWhitespace": "all",
	"editor.rulers": [
		80
	],
	"editor.smoothScrolling": true,
	"editor.tabCompletion": "on",
	"editor.unicodeHighlight.invisibleCharacters": true,
	"editor.wordWrap": "on",
	"editor.wrapOnEscapedLineFeeds": true,
	"editor.wrappingStrategy": "advanced",
	"files.associations": {
		"renv.lock": "json"
	},
	"git.blame.editorDecoration.enabled": true,
	"git.defaultCloneDirectory": "~/repos",
	"git.enableCommitSigning": true,
	"git.fetchOnPull": true,
	"github.copilot.chat.alternateGptPrompt.enabled": true,
	"github.copilot.chat.anthropic.thinking.enabled": true,
	"github.copilot.chat.anthropic.tools.websearch.enabled": true,
	"github.copilot.chat.codesearch.enabled": true,
	"github.copilot.chat.newWorkspace.useContext7": true,
	"github.copilot.chat.tools.memory.enabled": true,
	"notebook.lineNumbers": "on",
	"notebook.workingDirectory": "${workspaceFolder}",
	"positron.assistant.alwaysIncludeCopilotTools": true,
	"positron.assistant.enable": true,
	"positron.assistant.notebookMode.enable": true,
	"positron.assistant.toolDetails.enable": true,
	"positron.r.workspaceSymbols.includeCommentSections": true,
	"python.interpreters.exclude": [
		"/usr/bin/python3"
	],
	"python.pyrefly.disableLanguageServices": true,
	"python.terminal.shellIntegration.enabled": true,
	"rewrap.autoWrap.enabled": true,
	"rewrap.doubleSentenceSpacing": true,
	"rewrap.reformat": true,
	"terminal.external.osxExec": "/Applications/Ghostty.app",
	"terminal.integrated.defaultProfile.osx": "zsh",
	"terminal.integrated.smoothScrolling": true,
	"terminal.integrated.suggest.enabled": true,
	"window.autoDetectColorScheme": true,
	"workbench.keybindings.rstudioKeybindings": true,
	"[yaml]": {
		"editor.defaultFormatter": "quarto.quarto"
	}
}